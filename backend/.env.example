# InfoLoker Backend — Environment Variables
# Salin ke .env dan isi sebelum menjalankan server. JANGAN commit .env ke git!

PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=infoloker_db

JWT_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_EXPIRES_IN=24h
JWT_REMEMBER_EXPIRES_IN=7d

MAX_FILE_SIZE_CV=5242880
MAX_FILE_SIZE_FOTO=2097152
MAX_FILE_SIZE_LOGO=1048576

ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
